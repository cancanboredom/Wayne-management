rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── สมาชิก (shared ทุกเดือน) ──────────────────────────────
    match /sp/{document} {
      allow read, write: if true;
    }

    // ── Config รายเดือน (OFF, picks, conf, noon) ───────────────
    match /sp_cfg/{monthKey} {
      allow read, write: if true;
    }

    // ── Schedule ผลลัพธ์รายเดือน ──────────────────────────────
    match /sp_sched/{monthKey} {
      allow read, write: if true;
    }
  }
}

// หมายเหตุ: rules นี้เปิดให้ทุกคนที่มี URL อ่าน-เขียนได้
// เหมาะสำหรับใช้ภายในทีม
// ถ้าต้องการ login ก่อน ให้แก้เป็น: if request.auth != null;
