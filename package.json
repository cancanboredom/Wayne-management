{
  "name": "react-example",
  "private": true,
  "version": "5.3.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:lan": "tsx server.ts",
    "build": "vite build",
    "build:vercel": "vite build",
    "start": "tsx server.ts",
    "preview": "vite preview",
    "preview:lan": "vite preview --host 0.0.0.0 --port 4173",
    "deploy": "npm run build && firebase deploy",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\"",
    "changelog:check": "node scripts/check-changelog-format.mjs",
    "text-corruption:check": "node scripts/check-text-corruption.mjs",
    "changelog:push-check": "node scripts/enforce-changelog-on-push.mjs",
    "motion:check": "node scripts/check-motion-policy.mjs",
    "lint": "npm run motion:check && npm run changelog:check && npm run text-corruption:check && tsc --noEmit",
    "db:export:sqlite": "tsx scripts/export-sqlite-to-json.ts",
    "db:import:supabase": "tsx scripts/import-json-to-supabase.ts",
    "claude": "claude"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^11.10.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.63",
    "@types/date-fns": "^2.5.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "firebase-tools": "^15.8.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.1"
  },
  "overrides": {
    "vite": "$vite"
  }
}
